{
	"name": "obsidian-work-buddy",
	"version": "0.1.0",
	"description": "Companion Obsidian plugin for the work-buddy agent framework. Exposes an HTTP bridge for vault access, notifications, and JavaScript execution.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"work-buddy",
		"claude-code",
		"mcp",
		"agent-framework",
		"http-bridge",
		"vault-api"
	],
	"author": "KadenMc",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/KadenMc/obsidian-work-buddy.git"
	},
	"homepage": "https://github.com/KadenMc/obsidian-work-buddy",
	"bugs": {
		"url": "https://github.com/KadenMc/obsidian-work-buddy/issues"
	},
	"devDependencies": {
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
